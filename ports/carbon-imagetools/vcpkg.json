{
  "name": "carbon-imagetools",
  "version": "2.0.2",
  "description": "Provides Python bindings and C++ image processing utilities for Carbon projects.",
  "homepage": "https://github.com/carbonengine/imagetools",
  "license": "MIT",
  "supports": "(windows & x64) | osx",
  "dependencies": [
    {
      "name": "carbon-blueexposure",
      "version>=": "2.1.1"
    },
    {
      "name": "carbon-math",
      "version>=": "1.2.1"
    },
    {
      "name": "carbon-imageio",
      "version>=": "2.0.3"
    },
    {
      "name": "nvtt",
      "version>=": "2.1.2#9"
    },
    {
      "name": "zlib",
      "version>=": "2.2.5"
    },
    {
      "name": "libpng",
      "version>=": "1.6.47"
    },
    {
      "name": "libjpeg-turbo",
      "version>=": "2.1.2"
    },
    {
      "name": "openvdb",
      "version>=": "10.0.0",
      "features": [
        "nanovdb-nocuda"
      ],
      "default-features": false
    },
    {
      "name": "ccp-debug-info",
      "host": true,
      "version>=": "1.0.2"
    },
    {
      "name": "vcpkg-cmake",
      "host": true,
      "version>=": "2024-04-23"
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true,
      "version>=": "2024-05-23"
    }
  ]
}
